# MongoDB Configuration
# Replace with your MongoDB Atlas connection string
spring.mongodb.uri=${MONGO_URI:mongodb+srv://username:password@cluster.mongodb.net/?appName=SmartCampus}
spring.mongodb.database=smart_campus

# Server Configuration
server.port=8081

# Google OAuth2 Configuration
# Get your credentials from Google Cloud Console
spring.security.oauth2.client.registration.google.client-id=${GOOGLE_CLIENT_ID:your-client-id}
spring.security.oauth2.client.registration.google.client-secret=${GOOGLE_CLIENT_SECRET:your-client-secret}
spring.security.oauth2.client.registration.google.scope=email,profile

# JWT Configuration
# Use a secure random string for production
jwt.secret=${JWT_SECRET:your-secret-key}
jwt.expiration=86400000

# CORS Configuration
cors.allowed-origins=http://localhost:5173
